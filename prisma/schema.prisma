generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MagazineStatus {
  draft
  published
  unpublished
}

enum MagazineContentType {
  image
  web
}

model Magazine {
  id            String              @id @default(cuid())
  issueNumber   Int                 @unique
  title         String
  description   String?
  status        MagazineStatus      @default(draft)
  contentType   MagazineContentType @default(image)
  coverImageUrl String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  viewCount     Int                 @default(0)
  publishedAt   DateTime?
  pages         MagazinePage[]
  tocEntries    MagazineTocEntry[]
  articles      MagazineArticle[]

  @@index([status, publishedAt(sort: Desc)])
}

model MagazinePage {
  id         String   @id @default(cuid())
  magazineId String
  pageNumber Int
  imageUrl   String
  sortOrder  Int
  createdAt  DateTime @default(now())
  magazine   Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@unique([magazineId, sortOrder])
  @@index([magazineId, sortOrder])
}

model MagazineTocEntry {
  id         String   @id @default(cuid())
  magazineId String
  title      String
  pageNumber Int
  sortOrder  Int
  createdAt  DateTime @default(now())
  magazine   Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@index([magazineId, sortOrder])
}

model MagazineArticle {
  id           String         @id @default(cuid())
  magazineId   String
  title        String
  slug         String
  content      String         @default("") @db.Text
  author       String         @default("")
  section      String         @default("")
  thumbnailUrl String?
  sortOrder    Int
  isCoverStory Boolean        @default(false)
  status       BlogPostStatus @default(draft)
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  magazine     Magazine       @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@unique([magazineId, slug])
  @@index([magazineId, sortOrder])
}

enum BlogPostStatus {
  draft
  published
}

model BlogPost {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  content      String         @default("") @db.Text
  thumbnailUrl String?
  author       String         @default("")
  tags         String[]
  viewCount    Int            @default(0)
  status       BlogPostStatus @default(draft)
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, publishedAt(sort: Desc)])
}
